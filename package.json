{
  "name": "as400-web-emulator",
  "private": true,
  "version": "0.1.0",
  "description": "AS400 (IBM i) 5250 MCP server + Web emulator — pure TypeScript TN5250 implementation",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "gen:tables": "npm run gen -w @as400web/gen-tables"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
